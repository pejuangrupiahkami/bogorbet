---
import GroupFooterNav from "../blocks/GroupFooterNav.astro";
import Container from "../shared/Container.astro";
import FooterNav from "../shared/FooterNav.astro";
import Paragraph from "../shared/Paragraph.astro";

const TARGET = "https://lobby666.bogor.bet/?ref=Uz35ZZ";

const footerNav1 = [
    { itemText:"Marketing", itemLink: TARGET },
    { itemText:"Analylitics", itemLink: TARGET },
    { itemText:"Commerce", itemLink: TARGET },
    { itemText:"Insights", itemLink: TARGET }
];

const footerSupport = [
    { itemText:"Pricing", itemLink: TARGET },
    { itemText:"Guides", itemLink: TARGET },
    { itemText:"FAQ", itemLink: TARGET },
    { itemText:"Contact", itemLink: TARGET }
];

const footerCompany = [
    { itemText:"About", itemLink: TARGET },
    { itemText:"Blog", itemLink: TARGET },
    { itemText:"Jobs", itemLink: TARGET },
    { itemText:"Parteners", itemLink: TARGET },
    { itemText:"Jobs", itemLink: TARGET }
];

const footerLegal = [
    { itemText:"Claim", itemLink: TARGET },
    { itemText:"Privacy", itemLink: TARGET },
    { itemText:"Terms", itemLink: TARGET }
];
---

<div class="mt-16"></div>

<footer class="relative bg-gradient-to-tr from-gray-100 to-gray-200 dark:from-gray-900 dark:to-transparent pt-28 rounded-t-3xl">

    <div class="absolute right-0 top-0 h-full w-full flex justify-end">
        <div class="w-28 h-28 overflow-auto flex rounded-xl relative blur-2xl">
            <span class="absolute w-16 h-16 -top-1 -right-1 bg-green-500 rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary rounded-md rotate-45"></span>
        </div>
    </div>

    <div class="absolute left-0 bottom-0 h-full w-full flex items-end">
        <div class="w-28 h-28 overflow-auto flex rounded-xl relative blur-2xl">
            <span class="absolute w-16 h-16 -top-1 -right-1 bg-green-500 rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary rounded-md rotate-45"></span>
        </div>
    </div>

    <Container className="pb-8 relative overflow-auto">

        <!-- glow background -->
        <span class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 blur-2xl opacity-20 w-24 h-16 sm:w-48 sm:h-36 rounded-full rotate-12 skew-x-6 bg-primary"></span>

        <div class="grid grid-cols-2 lg:grid-cols-3 lg:items-stretch gap-8 relative">

            <!-- BRAND -->
            <div class="col-span-2 lg:col-span-1 h-auto flex flex-col">

                <div class="h-full">

                    <a href={TARGET} target="_blank" class="relative flex items-center gap-3">

                        <img
                            src="images/logo.png"
                            alt="Logo BOGORBET"
                            class="h-7 w-auto object-contain"
                        />

                        <div class="inline-flex text-lg font-semibold text-heading-1">
                            BOGORBET
                        </div>

                    </a>

                    <Paragraph className={"mt-8"}>
                        Platform slot terpercaya dengan akses cepat, aman, dan peluang menang tinggi setiap hari.
                    </Paragraph>

                </div>

                <!-- social links -->
                <div class="min-h-max flex items-center gap-4 text-heading-3 mt-8">

                    <a href={TARGET} target="_blank" class="transition hover:text-heading-1 hover:scale-105">FB</a>
                    <a href={TARGET} target="_blank" class="transition hover:text-heading-1 hover:scale-105">IG</a>
                    <a href={TARGET} target="_blank" class="transition hover:text-heading-1 hover:scale-105">TW</a>
                    <a href={TARGET} target="_blank" class="transition hover:text-heading-1 hover:scale-105">GH</a>

                </div>

            </div>

            <!-- NAV 1 -->
            <GroupFooterNav>
                <FooterNav title={"Company"} navItems={footerCompany}/>
                <FooterNav title={"Solutions"} navItems={footerNav1}/>
            </GroupFooterNav>

            <!-- NAV 2 -->
            <GroupFooterNav>
                <FooterNav title={"Support"} navItems={footerSupport}/>
                <FooterNav title={"Legal"} navItems={footerLegal}/>
            </GroupFooterNav>

        </div>

    </Container>

    <!-- bottom bar -->
    <div class="bg-gradient-to-tl from-box-bg py-2 relative">

        <Container>

            <div class="flex justify-between items-center gap-6 md:text-lg text-heading-3">

                <div>
                    &copy; <span id="year"></span> BOGORBET. All rights reserved 2026 ©
                </div>

                <div>
                    Made with 💚 by <a href={TARGET} target="_blank" class="font-semibold">bogorbet</a>
                </div>

            </div>

        </Container>

    </div>

</footer>